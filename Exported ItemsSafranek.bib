	url = {http://stacks.iop.org/1367-2630/17/i=7/a=073016},
	doi = {10.1088/1367-2630/17/7/073016},
	abstract = {Gaussian states are of increasing interest in the estimation of physical parameters because they are easy to prepare and manipulate in experiments. In this article, we derive formulae for the optimal estimation of parameters using two- and multi-mode Gaussian states. As an application of our result, we derive the optimal Gaussian probe states for the estimation of the parameter characterizing a one-mode squeezing channel.},
